@{
    int? lid = Context.Session.GetInt32("LogueadoId");
    string lrol = Context.Session.GetString("LogueadoRol");
    int cantidad = Context.Session.GetInt32("CantidadCarrito") ?? 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - webapp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/webapp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark gamer-navbar mb-3">
            <div class="container-fluid">

                <a class="navbar-brand gamer-logo">
                    🎮 GAME HUB
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1 align-items-center gap-2">

                        @if (lid == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link gamer-link"
                                   asp-controller="VideoJuego"
                                   asp-action="Index">
                                    🎮 Juegos
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link gamer-link"
                                   asp-controller="Home"
                                   asp-action="Index">
                                    🔐 Iniciar Sesion
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link gamer-link"
                                   asp-controller="Home"
                                   asp-action="Menu">
                                    🏠 Menu
                                </a>
                            </li>

                            @if (lrol == "Administrador")
                            {
                                <li class="nav-item">
                                    <a class="nav-link gamer-link"
                                       asp-controller="Cliente"
                                       asp-action="Index">
                                        👥 Clientes
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link gamer-link"
                                       asp-controller="Cliente"
                                       asp-action="VerMiPerfil">
                                        👤 Perfil
                                    </a>
                                </li>

                                <li class="nav-item ms-auto position-relative">
                                    <a asp-controller="Carrito"
                                       asp-action="Index"
                                       class="cart-btn">
                                        🛒
                                        <span class="cart-text">Carrito</span>
                                    </a>

                                    @if (cantidad > 0)
                                    {
                                        <span class="cart-badge">@cantidad</span>
                                    }
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link gamer-link logout"
                                   asp-controller="Auth"
                                   asp-action="Logout">
                                    🚪 Logout
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - webapp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

  
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
