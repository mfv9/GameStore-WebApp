@using DEMO2
@model List<VideoJuego>

@if (TempData["Mensaje"] != null)
{
    <div id="mensaje" class="mensaje-exito">
        @TempData["Mensaje"]
    </div>
}

<div class="container mt-5">

    <h1 class="titulo-gamer text-center mb-5">
        🎮 GAME STORE
    </h1>

    <form method="post" asp-controller="VideoJuego" asp-action="BuscarJuegos">
        <input type="text" id="buscador" class="search" placeholder="Buscar juegos" name="criterio" />

        <div id="resultados">
            <partial name="_ListaJuegos" model="Model" />
        </div>

        <script src="~/js/busqueda.js"></script>

        <p>@ViewBag.Error</p>
    </form>

    <div class="row row-cols-1 row-cols-md-4 g-4">

        @foreach (var juego in Model)
        {
            <div class="col">

                <div class="game-card">

                    <div class="game-img">
                        <img src="img/@juego.Foto" alt="@juego.Nombre">
                    </div>

                    <div class="game-body">

                        <h4>@juego.Nombre</h4>

                        @if (Context.Session.GetInt32("LogueadoId") != null)
                        {
                            <div class="precio">
                                $@juego.Precio
                            </div>

                            <form method="post"
                                  asp-action="Comprar"
                                  asp-controller="Carrito">

                                <input type="hidden" name="id" value="@juego.Id" />

                                @if (juego.DLC)
                                {
                                    <div class="dlc-box">

                                        @if (juego is Virtual v)
                                        {
                                            <span>DLC Premium (+$@v.CalcularPrecioRealSiLlevaOnoDlc(v.DLC))</span>
                                        }
                                        else if (juego is Fisico f)
                                        {
                                            <span>DLC Premium (+$@f.CalcularPrecioRealSiLlevaOnoDlc(f.DLC))</span>
                                        }

                                        <label class="switch">
                                            <input type="checkbox" name="dlc" value="true">
                                            <span class="slider"></span>
                                        </label>

                                    </div>
                                }

                                <button class="btn-comprar">
                                    🛒 Comprar
                                </button>

                            </form>
                        }

                    </div>

                </div>

            </div>
        }

    </div>

</div>

