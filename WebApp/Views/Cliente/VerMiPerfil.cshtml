@using DEMO2
@model Cliente

<div class="perfil-container">

    <h1>Mi Perfil</h1>

    <div class="perfil-card">

        <div class="perfil-header">
            <h2>@Model.Nombre</h2>

            @Html.ActionLink("✏️ Editar perfil", "Edit", new { id = Model.Id }, new { @class = "btn-editar" })
            @Html.ActionLink("✏️ Cambiar contraseña", "EditPass", new { id = Model.Id }, new { @class = "btn-editar" })

        </div>

        <dl class="perfil-info">

            <dt>Nombre</dt>
            <dd>@Model.Nombre</dd>

            <dt>Email</dt>
            <dd>@Model.Email</dd>

            <dt>Contraseña</dt>
            <dd>***********</dd>

            <dt>Fecha de nacimiento</dt>
            <dd>@Model.FechNac.ToShortDateString()</dd>

            <dt>Fecha de alta</dt>
            <dd>@Model.FechaAlta.ToShortDateString()</dd>

        </dl>

    </div>

</div>
    