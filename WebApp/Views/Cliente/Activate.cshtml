@using DEMO2
@model Cliente
<h1>Desactivar</h1>
<h3>¿Está seguro que desea desactivar esta persona?</h3>
<div>
    <form method="post">
        <input type="submit" value="Activar" class="btn btn-danger" /> |
        <input type="checkbox" name="IsChecked" value="true" /><span>Seguro que quiere activar al usuario?</span>
        <a asp-action="Index">Volver a la lista</a>
    </form>
</div>
<p>@ViewBag.msg</p>

}
