@{
    ViewData["Title"] = "Inicio";
}

<div class="hero guest" style="background-image:url('https://images.unsplash.com/photo-1605901309584-818e25960a8f');">

    <div class="overlay"></div>

    <div class="content text-center">

        <h1 class="display-4 text-white fw-bold">
            🎮 GameStore
        </h1>

        <p class="lead text-light mt-3">
            Tu universo de videojuegos en un solo lugar
        </p>

        <div class="mt-4">
            <a asp-controller="Auth"
               asp-action="Login"
               class="btn gamer-btn btn-lg me-2">
                Iniciar Sesión
            </a>

            <a asp-controller="Cliente"
               asp-action="Create"
               class="btn gamer-btn-outline btn-lg">
                Registrarse
            </a>
        </div>

        <p class="mt-4 text-secondary">
            Explora, compra y gestiona tus juegos favoritos
        </p>

    </div>

</div>